{
  "name": "trustinn-windowss",
  "version": "0.0.14",
  "description": "Trustinn Windows Electron application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "electron-dev": "electron .",
    "dev": "electron .",
    "dist": "electron-builder --win portable nsis",
    "package": "npm run dist"
  },
  "author": "Trustinn",
  "license": "MIT",
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.trustinn.windowss",
    "productName": "Trustinn Windows App",
    "icon": "logo/logo.png",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "package.json",
      "node_modules/**"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "logo"
    },
    "win": {
      "icon": "logo/logo.png",
      "artifactName": "Trustinn-Windows-App-Setup-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "logo/logo.ico",
      "uninstallerIcon": "logo/logo.ico",
      "installerHeaderIcon": "logo/logo.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "nitminer",
        "repo": "trustinn-windows"
      }
    ]
  }
}
